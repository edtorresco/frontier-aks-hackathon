{
    "name": "Frontier AKS Hackathon",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

    // Install all CLI tools students need via Dev Container Features
    "features": {
        // Azure CLI — latest stable
        "ghcr.io/devcontainers/features/azure-cli:1": {
            "version": "latest",
            "extensions": "aks-preview connectedk8s k8s-configuration k8s-extension"
        },
        // kubectl + kubelogin
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest",
            "helm": "latest",
            "minikube": "none"
        },
        // kubelogin (AAD / Entra token exchange for AKS)
        "ghcr.io/azure/azure-dev/azd:0": {},
        // Flux CLI v2
        "ghcr.io/devcontainers-contrib/features/flux2:1": {},
        // GitHub CLI
        "ghcr.io/devcontainers/features/github-cli:1": {},
        // Docker-in-Docker (for ACR Tasks / local image builds)
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },

    // VS Code extensions pre-installed inside the container
    "customizations": {
        "vscode": {
            "extensions": [
                // Azure & AKS
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-azureresourcegroups",
                "ms-azuretools.vscode-aks-tools",
                // GitOps / Flux
                "weaveworks.vscode-gitops-tools",
                // Helm
                "tim-koehler.helm-intellisense",
                // YAML (Kubernetes manifests)
                "redhat.vscode-yaml",
                // Docker
                "ms-azuretools.vscode-docker",
                // GitHub Copilot
                "GitHub.copilot",
                "GitHub.copilot-chat",
                // REST Client (for testing inference endpoints in AI track)
                "humao.rest-client",
                // Markdown preview
                "bierner.markdown-preview-github-styles"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "yaml.schemas": {
                    "kubernetes": "*.yaml"
                },
                "vs-kubernetes": {
                    "vs-kubernetes.crd-code-completion": "enabled"
                }
            }
        }
    },

    "remoteUser": "vscode",

    // Verify all tools are available after container creation
    "postCreateCommand": "bash .devcontainer/post-create.sh"
}
